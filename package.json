{
  "name": "f-saudidex-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths --resolve-full-extension .js",
    "start": "node dist/server.js",
    "lint": "tsc --project tsconfig.lint.json --noEmit",
    "worker:queue": "tsx scripts/queue-worker.ts",
    "engine": "tsx shared/engine/main.ts",
    "backup": "tsx scripts/backup-database.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@crawlee/cheerio": "^3.10.1",
    "@crawlee/playwright": "^3.10.1",
    "@crawlee/types": "^3.10.1",
    "@crawlee/utils": "^3.10.1",
    "@google-cloud/run": "^3.2.0",
    "@google/genai": "^1.29.0",
    "@huggingface/inference": "^4.13.15",
    "@mistralai/mistralai": "^2.1.2",
    "@supabase/supabase-js": "^2.103.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "crawlee": "^3.10.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.2",
    "groq-sdk": "^1.1.2",
    "openai": "^6.33.0",
    "papaparse": "^5.5.3",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "turndown": "^7.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/turndown": "^5.0.6",
    "@vercel/node": "^3.0.25",
    "pg": "^8.20.0",
    "supabase": "^2.95.5",
    "tsx": "^4.21.0",
    "tsc-alias": "^1.8.16",
    "typescript": "~5.8.2"
  }
}
