# Sao chép sang .env rồi điền giá trị (cùng tên biến với repo saudidex-backend / Render).
NODE_ENV=development
PORT=3000

# CORS: frontend Vite local (để trống = cho mọi origin khi dev, giống logic saudidex-backend)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Public site URL cho sitemap
VITE_APP_URL=http://localhost:5173
APP_URL=http://localhost:5173
APP_NAME=Saudidex

# Admin API (cron / Postman Bearer hoặc x-admin-secret — phải trùng frontend nếu dùng)
ADMIN_CURSOR_SECRET=change-me-local-admin-secret

# Supabase — copy từ project Supabase của bạn
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optionals (mirror biến trên một số script)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# AI backend (GEMINI được engine đọc từ process.env.GEMINI_API_KEY; Gemini client thường dùng thêm biến VITE_)
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
OPENAI_API_KEY=

OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Saudidex

VITE_AI_DISABLED=false
AI_DISABLED=false

VITE_ADMIN_EMAILS=

# Crawl / cloud
BROWSERLESS_TOKEN=
SCRAPINGBEE_API_KEY=
PLAYWRIGHT_BROWSERS_PATH=0

# GCP Cloud Run Jobs (nếu dùng)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=me-central1
CLOUD_RUN_JOB_NAME=

# Worker
QUEUE_WORKER_POLL_MS=3000
QUEUE_WORKER_FETCH_TIMEOUT_MS=20000

# DB scripts (backup / migration)
DATABASE_URL_POOLER=
